<UserControl x:Class="InvEntry.Views.OldMetalPurchaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:viewmodels="clr-namespace:InvEntry.ViewModels"
             xmlns:ext="clr-namespace:InvEntry.Extension"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=viewmodels:OldMetalPurchaseViewModel}"
             DataContext="{ext:DISource Type=viewmodels:OldMetalPurchaseViewModel}">

    <UserControl.Resources>

        <sys:String x:Key="OMPurchase">Old Metal Purchase</sys:String>

        <Style TargetType="{x:Type dxe:TextEdit}">
            <Setter Property="Width"
                    Value="150" />
            <Setter Property="Height"
                    Value="35" />
            <Setter Property="Margin"
                    Value="3" />
        </Style>

    </UserControl.Resources>

    <Grid Background="#FAFAFA"
          Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- =========================
 TOOLBAR
========================= -->

        <dxb:BarContainerControl Grid.Row="0">

            <dxb:MainMenuControl FontSize="14">

                <dxb:BarButtonItem Content="Reset"
                                   Glyph="{dx:DXImage 'Images/Actions/Refresh_32x32.png'}"
                                   GlyphAlignment="Top"
                                   BarItemDisplayMode="ContentAndGlyph"
                                   GlyphSize="Large"
                                   Command="{Binding ResetFormCommand}" />

                <dxb:BarItemSeparator />

                <dxb:BarButtonItem Content="Print"
                                   Glyph="{dx:DXImage 'Images/Print/PrintViaPDF_32x32.png'}"
                                   GlyphAlignment="Top"
                                   BarItemDisplayMode="ContentAndGlyph"
                                   GlyphSize="Large"
                                   Command="{Binding PrintPOCommand}" />

                <dxb:BarButtonItem Content="Preview"
                                   Glyph="{dx:DXImage 'Images/XAF/Action_Printing_Preview_32x32.png'}"
                                   GlyphAlignment="Top"
                                   BarItemDisplayMode="ContentAndGlyph"
                                   GlyphSize="Large"
                                   Command="{Binding PrintPreviewPurchaseCommand}" />

                <dxb:BarItemSeparator />

                <dxb:BarButtonItem Content="Save"
                                   Glyph="{dx:DXImage 'Images/Save/Save_32x32.png'}"
                                   GlyphAlignment="Top"
                                   BarItemDisplayMode="ContentAndGlyph"
                                   GlyphSize="Large"
                                   Command="{Binding CreatePurchaseOrderCommand}" />

            </dxb:MainMenuControl>

        </dxb:BarContainerControl>

        <!-- =========================
 HEADER SECTION
========================= -->

        <Grid Grid.Row="1"
              Margin="0,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- CUSTOMER CARD -->

            <Border Grid.Column="0"
                    Background="White"
                    Padding="15"
                    Margin="0,0,10,0"
                    CornerRadius="6"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">

                <dxlc:LayoutControl>

                    <dxlc:LayoutGroup View="GroupBox"
                                      GroupBoxDisplayMode="Light">
                        <dxlc:LayoutGroup.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Customer Details"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="Coral" />
                            </DataTemplate>
                        </dxlc:LayoutGroup.HeaderTemplate>

                        <dxlc:LayoutItem Label="Mobile">

                            <dxe:TextEdit EditValue="{Binding CustomerPhoneNumber}"
                                          Name="CustomerMobileNbr">

                                <dxmvvm:Interaction.Behaviors>

                                    <dxmvvm:EventToCommand EventName="EditValueChanged"
                                                           Command="{Binding FetchCustomerDetailsCommand}"
                                                           PassEventArgsToCommand="True" />

                                    <dxmvvm:EventToCommand EventName="Loaded"
                                                           Command="{Binding FocusCommand}"
                                                           CommandParameter="{Binding ElementName=CustomerMobileNbr}" />

                                </dxmvvm:Interaction.Behaviors>

                            </dxe:TextEdit>

                        </dxlc:LayoutItem>

                        <dxlc:LayoutItem Label="Name">
                            <dxe:TextEdit EditValue="{Binding Seller.CustomerName}"
                                          CharacterCasing="Upper"
                                          IsReadOnly="{Binding CustomerReadOnly}">
                                <dxmvvm:Interaction.Behaviors>
                                    <dxmvvm:EventToCommand EventName="EditValueChanged"
                                                           Command="{Binding CheckCustomerChangesCommand}"
                                                           PassEventArgsToCommand="True" />
                                </dxmvvm:Interaction.Behaviors>
                            </dxe:TextEdit>
                        </dxlc:LayoutItem>

                       
                        <dxlc:LayoutItem Label="City">

                            <dxe:TextEdit EditValue="{Binding Seller.Address.City}"
                                          CharacterCasing="Upper"
                                          IsReadOnly="{Binding CustomerReadOnly}" />

                        </dxlc:LayoutItem>

                        <dxlc:LayoutItem Label="State">

                            <dxe:ComboBoxEdit ItemsSource="{Binding StateReferencesList}"
                                              EditValue="{Binding CustomerState}"
                                              IsTextEditable="False"
                                              Width="200" />

                        </dxlc:LayoutItem>

                    </dxlc:LayoutGroup>

                </dxlc:LayoutControl>

            </Border>

            <!-- TRANSACTION CARD -->

            <Border Grid.Column="1"
                    Background="White"
                    Padding="15"
                    CornerRadius="6"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">

                <dxlc:LayoutControl>

                    <dxlc:LayoutGroup View="GroupBox"
                                      GroupBoxDisplayMode="Light">
                        <dxlc:LayoutGroup.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Old Purchase"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="Coral" />
                            </DataTemplate>
                        </dxlc:LayoutGroup.HeaderTemplate>
                        

                        <dxlc:LayoutItem Label="Purchase Number">

                            <TextBlock Text="{Binding OmTrans.TransNbr}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#2E7D32" />

                        </dxlc:LayoutItem>

                        <dxlc:LayoutItem Label="Date">

                            <dxe:DateEdit EditValue="{Binding OmTrans.TransDate}"
                                          IsReadOnly="True" />

                        </dxlc:LayoutItem>

                    </dxlc:LayoutGroup>

                </dxlc:LayoutControl>

            </Border>

        </Grid>

        <!-- =========================
 ITEMS GRID
========================= -->

        <Border Grid.Row="2"
                Background="White"
                Padding="10"
                CornerRadius="6"
                BorderBrush="#E0E0E0"
                BorderThickness="1">

            <!-- Second row: full width -->
            <dxlc:LayoutControl AllowItemSizing="True"
                                StretchContentVertically="False"
                                StretchContentHorizontally="False">
          <!--      Grid.Row="2"
                                Grid.ColumnSpan="2">  -->
                
                <dxlc:LayoutControl.Resources>
                    <Style x:Key="labelStyle"
                           TargetType="dxlc:LayoutItemLabel">
                        <Setter Property="FontWeight"
                                Value="Bold" />
                    </Style>
                    <Style TargetType="dxlc:LayoutItem">
                        <Setter Property="LabelStyle"
                                Value="{StaticResource labelStyle}" />
                    </Style>
                    <Style x:Key="NumberFormatWtStyle"
                           TargetType="dxe:TextEditSettings">
                        <Setter Property="MaskType"
                                Value="Numeric" />
                        <Setter Property="Mask"
                                Value="######.000" />
                        <Setter Property="MaskShowPlaceHolders"
                                Value="False" />
                        <Setter Property="MaskUseAsDisplayFormat"
                                Value="True" />
                        <Setter Property="dxe:NumericMaskOptions.AlwaysShowDecimalSeparator"
                                Value="False" />
                    </Style>
                    <Style x:Key="NumberFormatStyle"
                           TargetType="dxe:TextEdit">
                        <Setter Property="MaskType"
                                Value="Numeric" />
                        <Setter Property="Mask"
                                Value="#,##,##,##,###.00" />
                        <Setter Property="MaskShowPlaceHolders"
                                Value="False" />
                        <Setter Property="MaskUseAsDisplayFormat"
                                Value="True" />
                        <Setter Property="Width"
                                Value="150" />
                        <Setter Property="Height"
                                Value="35" />
                    </Style>
                    <Style x:Key="NumberFormatEditSettingsStyle"
                           TargetType="dxe:TextEditSettings">
                        <Setter Property="MaskType"
                                Value="Numeric" />
                        <Setter Property="Mask"
                                Value="#,##,##,##,###.00" />
                        <Setter Property="MaskShowPlaceHolders"
                                Value="False" />
                        <Setter Property="MaskUseAsDisplayFormat"
                                Value="True" />
                        <Setter Property="AllowNullInput"
                                Value="False" />
                    </Style>
                    <DataTemplate x:Key="RsTemplate">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding}" />
                            <TextBlock Text="(Rs.)"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       FontSize="9"
                                       Margin="5,0,0,0"
                                       Width="20" />
                            <!-- Margin: Left,Top,Right,Bottom-->
                        </StackPanel>
                    </DataTemplate>
                </dxlc:LayoutControl.Resources>


                <dxlc:LayoutGroup View="Tabs">

                    <dxlc:LayoutGroup >
                        <dxlc:LayoutGroup.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Item Details"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="Coral" />
                            </DataTemplate>
                        </dxlc:LayoutGroup.HeaderTemplate>
                        
                            
                        <dxlc:LayoutItem>
                            <dxb:BarManager AllowCustomization="False">
                                <dxb:BarManager.Bars>
                                    <dxb:Bar AllowCollapse="False"
                                             AllowQuickCustomization="False"
                                             AllowRemove="False"
                                             AllowCustomizationMenu="False"
                                             ShowDragWidget="False">
                                        <dxb:BarEditItem EditValue="{Binding ProductIdUI}"
                                                         Content="Product Id"
                                                         EditWidth="250"
                                                         EditHeight="30">
                                            <dxb:BarEditItem.EditSettings>
                                                <dxe:ComboBoxEditSettings ItemsSource="{Binding MetalList}" />
                                            </dxb:BarEditItem.EditSettings>
                                        </dxb:BarEditItem>
                                        <dxb:BarButtonItem Glyph="{dx:DXImage 'SvgImages/Icon Builder/Actions_AddCircled.svg'}"
                                                           Command="{Binding FetchProductCommand}"
                                                           GlyphSize="Large"
                                                           GlyphAlignment="Right"
                                                           BarItemDisplayMode="ContentAndGlyph" />
                                        <dxb:BarItemSeparator />
                                        <!--       <dxb:BarButtonItem Glyph="{dx:DXImage 'Images/Actions/Cancel_32x32.png'}" 
                                                 Command="{Binding DeleteRowsCommand}" GlyphSize="Large" 
                                                 Content="Delete" GlyphAlignment="Right"/> -->
                                    </dxb:Bar>
                                </dxb:BarManager.Bars>

                                <dxg:GridControl ItemsSource="{Binding OmTransUIList}"
                                                 DeleteKeyBehavior="DeleteFocusedRow"
                                                 FontSize="13"
                                                 MaxHeight="600"
                                                 MinHeight="400"
                                                 Width="1400"
                                                 SelectedItems="{Binding SelectedRows}"
                                                 HorizontalAlignment="Left">
                                    <dxg:GridControl.Resources>
                                        <Style x:Key="boldHeader"
                                               TargetType="dxg:BaseGridHeader">
                                            <Setter Property="FontWeight"
                                                    Value="Bold" />
                                        </Style>
                                        <Style TargetType="dxg:GridColumn">
                                            <Setter Property="HeaderStyle"
                                                    Value="{StaticResource boldHeader}" />
                                        </Style>
                                        <Style TargetType="dxe:TextEdit">
                                            <Setter Property="Width"
                                                    Value="Auto" />
                                            <Setter Property="EditValuePostMode"
                                                    Value="Immediate" />
                                        </Style>
                                    </dxg:GridControl.Resources>
                                    
                                    <dxg:GridControl.Columns>
                                        <dxg:GridColumn FieldName="ProductId"
                                                        Header="Product Id"
                                                        Width="250"
                                                        ReadOnly="True" />
                                        
                                        <dxg:GridColumn FieldName="Purity"
                                                        Header="Purity"
                                                        ReadOnly="True"
                                                        Width="100" />
                                        
                                        <dxg:GridColumn FieldName="TransactedRate"
                                                        Header="Rate"
                                                        Width="120"
                                                        ReadOnly="True">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:TextEditSettings Style="{StaticResource NumberFormatEditSettingsStyle}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>

                                        <dxg:GridColumn FieldName="ProdQty"
                                                        Header="Qty"
                                                        Width="100"
                                                        ReadOnly="False" />
                                        
                                        <dxg:GridColumn FieldName="GrossWeight"
                                                        Header="Gross Wt."
                                                        Width="120">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:TextEditSettings Style="{StaticResource NumberFormatWtStyle}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>

                                        <dxg:GridColumn FieldName="StoneWeight"
                                                        Header="Stone Wt."
                                                        Width="120">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:TextEditSettings Style="{StaticResource NumberFormatWtStyle}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>
                                        
                                        <dxg:GridColumn FieldName="NetWeight"
                                                        Header="Net Wt."
                                                        Width="120"
                                                        ReadOnly="True">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:TextEditSettings Style="{StaticResource NumberFormatWtStyle}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>
                                        
                                        <dxg:GridColumn FieldName="WastagePercent"
                                                        Header="Wastage (%)"
                                                        Width="100">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:TextEditSettings Style="{StaticResource NumberFormatEditSettingsStyle}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>

                                        <dxg:GridColumn FieldName="TotalProposedPrice"
                                                        Header="Purchase Amount (Rs)"
                                                        Width="150"
                                                        ReadOnly="True">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:TextEditSettings Style="{StaticResource NumberFormatEditSettingsStyle}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>

                                        <dxg:GridColumn FieldName="FinalPurchasePrice"
                                                        Header="Final Amount (Rs)"
                                                        Width="150" >
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:TextEditSettings Style="{StaticResource NumberFormatEditSettingsStyle}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>

                                    </dxg:GridControl.Columns>

                                    <dxg:GridControl.TotalSummary>
                                        <dxg:GridSummaryItem SummaryType="Sum"
                                                             Alignment="Default"
                                                             DisplayFormat="Taxable = {0}"
                                                             FieldName="InvlTaxableAmount" />

                                        <dxg:GridSummaryItem SummaryType="Sum"
                                                             Alignment="Default"
                                                             DisplayFormat="Total = {0}"
                                                             FieldName="InvlTotal" />
                                    </dxg:GridControl.TotalSummary>
                                    
                                    <dxg:GridControl.View>
                                        <dxg:TableView AllowGrouping="False"
                                                       AllowBestFit="True"
                                                       ShowGroupPanel="False"
                                                       TotalSummaryPosition="Bottom">
                                            <dxmvvm:Interaction.Behaviors>
                                                <dxmvvm:EventToCommand EventName="CellValueChanged"
                                                                       Command="{Binding CellUpdateCommand}"
                                                                       PassEventArgsToCommand="True" />
                                            </dxmvvm:Interaction.Behaviors>
                                            <dxg:TableView.RowCellMenuCustomizations>
                                                <dxb:BarButtonItem CommandParameter="{Binding Row.Row}"
                                                                   Command="{Binding DataContext.DeleteSingleRowCommand, 
                                                            RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                                   Glyph="{dx:DXImage 'Images/Edit/Delete_32x32.png'}"
                                                                   Content="Delete Row" />
                                            </dxg:TableView.RowCellMenuCustomizations>
                                        </dxg:TableView>
                                    </dxg:GridControl.View>
                                </dxg:GridControl>


                            </dxb:BarManager>
                        </dxlc:LayoutItem>
                    </dxlc:LayoutGroup>
                </dxlc:LayoutGroup>
            </dxlc:LayoutControl>
        </Border>

    </Grid>

</UserControl>