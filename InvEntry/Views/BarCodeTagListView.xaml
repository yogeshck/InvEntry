<dxwui:NavigationPage x:Class="InvEntry.Views.BarCodeTagListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InvEntry.Views"
             xmlns:dxwui="http://schemas.devexpress.com/winfx/2008/xaml/windowsui"
             xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             mc:Ignorable="d"
             xmlns:viewmodels="clr-namespace:InvEntry.ViewModels"
             xmlns:behavior="clr-namespace:InvEntry.Behavior"
             xmlns:ext="clr-namespace:InvEntry.Extension"
             d:DataContext="{d:DesignInstance Type=viewmodels:BarCodeTagListViewModel}"
             DataContext="{ext:DISource Type=viewmodels:BarCodeTagListViewModel}"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--<Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>-->
        <dxb:BarContainerControl>

            <dxb:MainMenuControl FontSize="15"
                                 Height="60">

                <dxb:BarEditItem Content="Category"
                                 EditWidth="150"
                                 EditHeight="35"
                                 EditValue="{Binding SelectedCategory}">
                    <dxb:BarEditItem.EditSettings>
                        <dxe:ComboBoxEditSettings ItemsSource="{Binding ProductCategoryList}"
                                                  IsTextEditable="False" />
                    </dxb:BarEditItem.EditSettings>
                </dxb:BarEditItem>

                <dxb:BarEditItem Content="BarCode"
                                 EditWidth="150"
                                 EditHeight="35"
                                 EditValue="{Binding SelectedProductSku}">
                    <dxb:BarEditItem.EditSettings>
                        <dxe:ComboBoxEditSettings ItemsSource="{Binding ProductSkuStrList}"
                                                  IsTextEditable="False" />
                    </dxb:BarEditItem.EditSettings>
                </dxb:BarEditItem>

                <dxb:BarEditItem   EditValue="{Binding OptionsStr}"
                                   Content="Options"
                                   EditWidth="150"
                                   EditHeight="30">
                </dxb:BarEditItem>

                <dxb:BarButtonItem x:Name="btnRefresh"
                                   Content="Refresh"
                                   Glyph="{dx:DXImage 'Images/Actions/Refresh_32x32.png'}"
                                   GlyphSize="Large"
                                   Command="{Binding RefreshBarcodeCommand}" />
                <dxb:BarItemSeparator Margin="2,0,2,0" />

                <dxb:BarButtonItem x:Name="btnPrintGrid"
                                   Content="Export"
                                   Glyph="{dx:DXImage 'Images/Print/PrintViaPDF_32x32.png'}"
                                   GlyphSize="Large"
                                   BarItemDisplayMode="ContentAndGlyph"
                                   GlyphAlignment="Top" />
                <dxb:BarItemSeparator Margin="2,0,2,0" />

                <dxb:BarButtonItem x:Name="btnClearForm"
                                   Content="Clear"
                                   Glyph="{dx:DXImage 'Images/Print/PrintViaPDF_32x32.png'}"
                                   GlyphSize="Large"
                                   Alignment="Far"
                                   BarItemDisplayMode="ContentAndGlyph"
                                   GlyphAlignment="Top"
                                   Command="{Binding ResetFormCommand}" />

            </dxb:MainMenuControl>
        </dxb:BarContainerControl>

        <dxg:GridControl Grid.Row="1"
                         ItemsSource="{Binding ProductStockList}"
                         AutoGenerateColumns="None"
                         x:Name="BarcodeGrid"
                         MinHeight="500"
                         Height="800"
                         MaxHeight="900"
                         MinWidth="800"
                         Width="1450"
                         SelectedItem="{Binding SelectedGridLine}"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top">
            <dxmvvm:Interaction.Behaviors>
                <dxmvvm:EventToCommand EventName="SelectedItemChanged"
                                       Command="{Binding SelectionChangedCommand}" />
                <behavior:PrintGridBehavior BarButtonItem="{Binding ElementName=btnPrintGrid}" />
            </dxmvvm:Interaction.Behaviors>
            <dxg:GridControl.View>
                <dxg:TableView ShowGroupPanel="False"
                               AllowBestFit="True"
                               x:Name="BarcodeTableview"
                               EditorButtonShowMode="ShowForFocusedCell"
                               AllowEditing="True"
                               AllowGrouping="False"
                               ShowAutoFilterRow="True"
                               AutoWidth="False"
                               ShowTotalSummary="True" />
            </dxg:GridControl.View>

            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="ProductSku"
                                Header="Product ID"
                                Width="110" />
                <dxg:GridColumn FieldName="Category"
                                Header="Category"
                                Width="90" />
                <dxg:GridColumn FieldName="GrossWeight"
                                Header="Gross"
                                Width="100" />
                <dxg:GridColumn FieldName="StoneWeight"
                                Header="Stone"
                                Width="100" />
                <dxg:GridColumn FieldName="NetWeight"
                                Header="Net"
                                Width="100" />
                
                <!-- Submit Button Column -->
                <dxg:GridColumn Header="Print"
                                Width="80">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Print"
                                    Command="{Binding DataContext.PrintTagCommand, 
                                      RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                    CommandParameter="{Binding RowData.Row}"
                                    
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
            </dxg:GridControl.Columns>

        </dxg:GridControl>

    </Grid>
    </dxwui:NavigationPage>
