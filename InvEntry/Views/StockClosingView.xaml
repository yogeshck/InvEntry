<UserControl x:Class="InvEntry.Views.StockClosingView"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:behavior="clr-namespace:InvEntry.Behavior"
             xmlns:viewmodels="clr-namespace:InvEntry.ViewModels"
             xmlns:ext="clr-namespace:InvEntry.Extension"
             xmlns:local="clr-namespace:InvEntry.Views"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid HorizontalAlignment="Left"
          Width="1300"
          Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <dxg:GridControl Grid.Row="1"
                         Grid.ColumnSpan="2"
                         ItemsSource="{Binding GrnLineList}"
                         SelectedItem="{Binding SelectedGrnLine, Mode=TwoWay}"
                         AutoGenerateColumns="None"
                         Margin="0,10,0,0"
                         HorizontalAlignment="Left"
                         Width="1300"
                         VerticalAlignment="Top">
            <dxg:GridControl.View>
                <dxg:TableView  x:Name="tableView3"
                                AllowGrouping="False"
                                ShowGroupPanel="False"
                                ShowAutoFilterRow="False"
                                AutoWidth="False"
                                TotalSummaryPosition="Bottom"
                                VerticalScrollbarVisibility="Auto"
                                AllowEditing="True"
                                EditorShowMode="MouseDown"
                                RowMinHeight="30">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand EventName="CellValueChanged"
                                               Command="{Binding CellUpdateCommand}"
                                               PassEventArgsToCommand="True" />
                        <!-- New binding for editor activation -->
                        <dxmvvm:EventToCommand EventName="ShowingEditor"
                                               Command="{Binding EditorActivatedCommand}"
                                               PassEventArgsToCommand="True" />
                        <dxmvvm:EventToCommand EventName="ValidateCell"
                                               Command="{Binding ValidateCellCommand}"
                                               PassEventArgsToCommand="True" />


                    </dxmvvm:Interaction.Behaviors>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Ref"
                                Header="Ref #"
                                ReadOnly="True"
                                Width="40" />
                <dxg:GridColumn FieldName="LineNbr"
                                Header="Line #"
                                ReadOnly="True"
                                Width="40" />
                <dxg:GridColumn FieldName="ProductSku"
                                Header="Sku"
                                ReadOnly="True"
                                Width="120" />
                <dxg:GridColumn FieldName="GrossWeight"
                                Header="Gross Wt"
                                Width="90"
                                AllowedTotalSummaries="Sum">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings Style="{StaticResource NumberFormatStyle}" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>

                <dxg:GridColumn FieldName="StoneWeight"
                                Header="Stone Wt"
                                Width="90">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings Style="{StaticResource NumberFormatStyle}" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="NetWeight"
                                Header="Net Wt"
                                Width="90">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings Style="{StaticResource NumberFormatStyle}" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="SuppliedQty"
                                Header="Supp Qty"
                                Width="60" />
                <dxg:GridColumn FieldName="OrderedQty"
                                Header="Ord Qty"
                                Width="60"
                                ReadOnly="True" />

                <!-- Submit Button Column 
                <dxg:GridColumn Header="Print"
                                Width="80">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Print"
                                    Command="{Binding DataContext.PrintTagCommand, 
                                      RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                    CommandParameter="{Binding RowData.Row}"
                                    IsEnabled="{Binding RowData.Row.IsPrinted, Converter={StaticResource NegationConverter}}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                -->

            </dxg:GridControl.Columns>
            
        </dxg:GridControl>

        <dxg:GridControl Grid.Row="2">

            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Ref"
                                Header="Ref #"
                                ReadOnly="True"
                                Width="40" />
                <dxg:GridColumn FieldName="LineNbr"
                                Header="Line #"
                                ReadOnly="True"
                                Width="40" />
                <dxg:GridColumn FieldName="ProductSku"
                                Header="Sku"
                                ReadOnly="True"
                                Width="120" />
                <dxg:GridColumn FieldName="GrossWeight"
                                Header="Gross Wt"
                                Width="90"
                                AllowedTotalSummaries="Sum">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings Style="{StaticResource NumberFormatStyle}" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>

                <dxg:GridColumn FieldName="StoneWeight"
                                Header="Stone Wt"
                                Width="90">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings Style="{StaticResource NumberFormatStyle}" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="NetWeight"
                                Header="Net Wt"
                                Width="90">
                    <dxg:GridColumn.EditSettings>
                        <dxe:TextEditSettings Style="{StaticResource NumberFormatStyle}" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>
                <dxg:GridColumn FieldName="SuppliedQty"
                                Header="Supp Qty"
                                Width="60" />
                <dxg:GridColumn FieldName="OrderedQty"
                                Header="Ord Qty"
                                Width="60"
                                ReadOnly="True" />

                <!-- Submit Button Column 
                <dxg:GridColumn Header="Print"
                                Width="80">
                    <dxg:GridColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Print"
                                    Command="{Binding DataContext.PrintTagCommand, 
                                      RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                    CommandParameter="{Binding RowData.Row}"
                                    IsEnabled="{Binding RowData.Row.IsPrinted, Converter={StaticResource NegationConverter}}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                        </DataTemplate>
                    </dxg:GridColumn.CellTemplate>
                </dxg:GridColumn>
                -->

            </dxg:GridControl.Columns>
            
        </dxg:GridControl>

    </Grid>

</UserControl>
