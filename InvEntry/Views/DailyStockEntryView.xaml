<UserControl x:Class="InvEntry.Views.DailyStockEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm" 
             xmlns:local="clr-namespace:InvEntry.Views"
             xmlns:viewmodels="clr-namespace:InvEntry.ViewModels"
             xmlns:ext="clr-namespace:InvEntry.Extension"
             xmlns:behavior="clr-namespace:InvEntry.Behavior"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewmodels:DailyStockEntryViewModel}"
             DataContext="{ext:DISource Type=viewmodels:DailyStockEntryViewModel}"
             Height="600" Width="1200" >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu -->
            <RowDefinition Height="Auto"/>
            <!-- DailyStocks grid -->
            <RowDefinition Height="1*"/>
            <!-- Summary grid -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <dxb:BarContainerControl Grid.Row="0">
            <dxb:MainMenuControl FontSize="15" Height="60">
                <dxb:BarEditItem EditValue="{Binding SelectedDate}" EditWidth="120" Content="From Date">
                    <dxb:BarEditItem.EditSettings>
                        <dxe:DateEditSettings AllowDefaultButton="True"/>
                    </dxb:BarEditItem.EditSettings>
                </dxb:BarEditItem>

                <dxb:BarButtonItem Content="Prev Date"
                   Glyph="{dx:DXImage 'Images/Navigation/Backward_32x32.png'}"
                   GlyphSize="Large"
                   Command="{Binding RefreshPrevDateCommand}" />

                <dxb:BarButtonItem Content="Refresh"
                                   Glyph="{dx:DXImage 'Images/Actions/Refresh_32x32.png'}"
                                   GlyphSize="Large"
                                   Command="{Binding RefreshDailyStockSummaryCommand}" />

                <dxb:BarButtonItem Content="Next Date"
                   Glyph="{dx:DXImage 'Images/Navigation/Forward_32x32.png'}"
                   GlyphSize="Large"
                   Command="{Binding RefreshNextDateCommand}"
                   IsEnabled="{Binding CanGoNext}" />

                <dxb:BarItemSeparator Margin="2,0,2,0"/>

                <dxb:BarButtonItem Content="Add Row"
                                       Glyph="{dx:DXImage 'Images/Actions/Add_32x32.png'}"
                                        GlyphSize="Large"
                                       Command="{Binding AddRowCommand}" />

                <dxb:BarButtonItem Content="Export"
                                   Glyph="{dx:DXImage 'Images/Print/PrintViaPDF_32x32.png'}"
                                   GlyphSize="Large"
                                   BarItemDisplayMode="ContentAndGlyph"
                                   GlyphAlignment="Top" />
                <dxb:BarItemSeparator Margin="2,0,2,0"/>

            </dxb:MainMenuControl>
        </dxb:BarContainerControl>

        <!-- DailyStocks Grid -->
        <dxg:GridControl Grid.Row="1"  AutoGenerateColumns="None"
                         Height="50">
            <dxg:GridControl.View>
                <dxg:TableView ShowGroupPanel="False" AllowEditing="False"/>
            </dxg:GridControl.View>

            <dxg:GridControl.Columns>
                <!-- Metal Column -->
                <dxg:GridColumn FieldName="Metal" Width="100" AllowEditing="False">
                    <dxg:GridColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Metal" FontSize="14"  FontWeight="Bold" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </dxg:GridColumn.HeaderTemplate>
                </dxg:GridColumn>

                <!-- Category Column -->
                <dxg:GridColumn FieldName="ProductCategory" Width="150" AllowEditing="False">
                    <dxg:GridColumn.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="Category" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </dxg:GridColumn.HeaderTemplate>
                </dxg:GridColumn>

                <!-- Opening -->
                <dxg:GridColumn FieldName="OpeningQty" Width="160">
                    <dxg:GridColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Opening" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                                    <TextBlock FontSize="14" Text="Qty" Margin="20,0,40,0"/>
                                    <TextBlock FontSize="14" Text="Weight"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </dxg:GridColumn.HeaderTemplate>
                </dxg:GridColumn>

                <!-- Stock In -->
                <dxg:GridColumn FieldName="StockInQty" Width="160"
                                AllowEditing="True" ReadOnly="False">
                    <dxg:GridColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Stock In" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                                    <TextBlock FontSize="14" Text="Qty" Margin="20,0,40,0"/>
                                    <TextBlock FontSize="14" Text="Weight"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </dxg:GridColumn.HeaderTemplate>
                </dxg:GridColumn>

                <!-- Stock Out -->
                <dxg:GridColumn FieldName="StockOutQty" Width="160">
                    <dxg:GridColumn.HeaderTemplate>
                        <DataTemplate>
                            <Border Background="YellowGreen" Padding="4">
                                <StackPanel>
                                    <TextBlock Text="Stock Out" FontSize="15" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,2,0,0">
                                        <TextBlock FontSize="14" Text="Qty" Foreground="Black"  Margin="20,0,40,0"/>
                                        <TextBlock FontSize="14" Text="Weight" Foreground="Black"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </dxg:GridColumn.HeaderTemplate>
                </dxg:GridColumn>

                <!-- Closing -->
                <dxg:GridColumn FieldName="ClosingQty" Width="160" AllowEditing="False">
                    <dxg:GridColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="Closing" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,0">
                                    <TextBlock FontSize="14" Text="Qty" Margin="20,0,40,0"/>
                                    <TextBlock FontSize="14" Text="Weight"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </dxg:GridColumn.HeaderTemplate>
                </dxg:GridColumn>
            </dxg:GridControl.Columns>
        </dxg:GridControl>

        <dxg:GridControl Grid.Row="2"
                 ItemsSource="{Binding DailyStockSummaryList}"
                 AutoGenerateColumns="None">
            <dxg:GridControl.View>
                <dxg:TableView ShowColumnHeaders="False"
                    AllowEditing="True"
                       ShowGroupPanel="False"
                       CellValueChangedCommand="{Binding OnCellUpdateCommand}"
                       ShowingEditor="TableView_ShowingEditor">
                    <dxmvvm:Interaction.Behaviors>
                        <dxmvvm:EventToCommand EventName="CellValueChanged"
                                       Command="{Binding CellUpdateCommand}"
                                       PassEventArgsToCommand="True" />
                    </dxmvvm:Interaction.Behaviors>
                </dxg:TableView>
            </dxg:GridControl.View>

            <dxg:GridControl.Columns>
                <dxg:GridColumn FieldName="Metal" Width="100"/>
                <dxg:GridColumn FieldName="ProductCategory" Width="150"/>

                <dxg:GridColumn FieldName="OpeningStockQty" Header="Opening Qty" Width="60">
                    <dxg:GridColumn.EditSettings>
                        <dxe:SpinEditSettings IsEnabled="{Binding IsObEditable}" />
                    </dxg:GridColumn.EditSettings>
                </dxg:GridColumn>

                <dxg:GridColumn FieldName="OpeningStockNetWeight" Width="100"
                                  AllowEditing="{Binding IsOpeningEditable}" />
                <dxg:GridColumn FieldName="StockInQty" Width="60"/>
                <dxg:GridColumn FieldName="StockInNetWeight" Width="100"/>
                <dxg:GridColumn FieldName="StockOutQty" Width="60"/>
                <dxg:GridColumn FieldName="StockOutNetWeight" Width="100"/>
                <dxg:GridColumn FieldName="ClosingStockQty" Width="60" AllowEditing="False"/>
                <dxg:GridColumn FieldName="ClosingStockNetWeight" Width="100" AllowEditing="False"/>
            </dxg:GridControl.Columns>
        </dxg:GridControl>

        <Border Grid.Row="3"
                Background="Wheat"
                Padding="8"
                CornerRadius="4"
                Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{Binding StatusBrush}"
                       FontSize="16"
                       FontWeight="Bold" 
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="3" Margin="10">
            <Button Content="Save" Width="100" Margin="5" Command="{Binding SaveCommand}" />
            <Button Content="Cancel" Width="100" Margin="5" Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>

</UserControl>


