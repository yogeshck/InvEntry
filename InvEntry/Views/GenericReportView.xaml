<dxwui:NavigationPage x:Class="InvEntry.Views.GenericReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dxwui="http://schemas.devexpress.com/winfx/2008/xaml/windowsui"   
             xmlns:dxdo="http://schemas.devexpress.com/winfx/2008/xaml/docking"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxb="http://schemas.devexpress.com/winfx/2008/xaml/bars"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:dxlc="http://schemas.devexpress.com/winfx/2008/xaml/layoutcontrol"
             xmlns:dxmvvm="http://schemas.devexpress.com/winfx/2008/xaml/mvvm"
             xmlns:local="clr-namespace:InvEntry.Views"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:behavior="clr-namespace:InvEntry.Behavior"
             xmlns:viewmodels="clr-namespace:InvEntry.ViewModels"
             xmlns:ext="clr-namespace:InvEntry.Extension"
             d:DataContext="{d:DesignInstance Type=viewmodels:GenericReportViewModel}"
             DataContext="{ext:DISource Type=viewmodels:GenericReportViewModel}"
             mc:Ignorable="d"
             HorizontalAlignment="Left"
             d:DesignHeight="650"
             d:DesignWidth="1800">

    <Grid Width="1800" HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>


        <dxb:BarContainerControl>
            <dxb:MainMenuControl FontSize="15" Height="60">
                <!-- ComboBox for selecting type 

                <dxb:BarEditItem IsReadOnly="True">
                    <dxb:BarEditItem.EditTemplate>
                        <DataTemplate>
                            <TextBlock Text="Daily Sales Receipts"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </dxb:BarEditItem.EditTemplate>
                </dxb:BarEditItem>   -->

                <!-- Page Title -->
                <dxb:BarStaticItem Content="Daily Sales Receipts"
                       ContentTemplate="{StaticResource BarTitleTemplate}" />

                <dxb:BarItemSeparator />

                <dxb:BarEditItem    EditValue="{Binding SearchOption.From}" 
                                    EditWidth="120" Content="From Date" >
                    <dxb:BarEditItem.EditSettings >
                        <dxe:DateEditSettings AllowDefaultButton="True" />
                    </dxb:BarEditItem.EditSettings>
                </dxb:BarEditItem>
                
                <dxb:BarEditItem    EditValue="{Binding SearchOption.To}" 
                                    EditWidth="120" Content="To Date">
                    <dxb:BarEditItem.EditSettings>
                        <dxe:DateEditSettings AllowDefaultButton="True" MaxValue="{Binding Today}" />
                    </dxb:BarEditItem.EditSettings>
                </dxb:BarEditItem>
                
                <dxb:BarEditItem   EditValue="{Binding SearchOption.Filter1}"
                                   Content="Invoice"
                                   EditWidth="150"
                                   EditHeight="30">
                </dxb:BarEditItem>

                <dxb:BarButtonItem x:Name="btnRefresh" Content="Refresh"
                                    Glyph="{dx:DXImage 'Images/Actions/Refresh_32x32.png'}"
                                    GlyphSize="Large"
                                    Command="{Binding RefreshDataCommand}" />

                <dxb:BarButtonItem  x:Name="btnPrintGrid"
                                    Content="Export"
                                    ItemClick="btnPrintGrid_ItemClick"
                                    Glyph="{dx:DXImage 'Images/Print/PrintViaPDF_32x32.png'}"
                                    GlyphSize="Large"
                                    BarItemDisplayMode="ContentAndGlyph"
                                    GlyphAlignment="Top" />

                <!--         <dxb:BarButtonItem x:Name="btnPrintGrid"
                                   Content="Export"
                                   ItemClick="btnPrintGrid_ItemClick"
                                   GlyphSize="Large"
                                   Glyph="{dx:DXImage 'Images/Print/PrintViaPDF_32x32.png'}" 
                                   BarItemDisplayMode="ContentAndGlyph"
                                   CommandParameter="{Binding ElementName=gridControl}"
                                   GlyphAlignment="Top"  />   -->

                <dxb:BarItemSeparator Margin="2,0,2,0" />

            </dxb:MainMenuControl>

        </dxb:BarContainerControl>

        <dxg:GridControl x:Name="gridControl"
                         Grid.Row="1" 
                         ItemsSource="{Binding GenericItems.DefaultView}" 
                         ItemsSourceChanged="gridControl_ItemsSourceChanged"
                         AutoGenerateColumns="AddNew"
                         AutoGeneratedColumns="gridControl_AutoGeneratedColumns"
                         MinHeight="500"
                         Height="800"
                         MaxHeight="1900"
                         MinWidth="1200"
                         Width="1800"  
                         HorizontalAlignment="Left" 
                         VerticalAlignment="Top">
            
            <dxg:GridControl.View>
                <dxg:TableView ShowGroupPanel="False"
                   ShowTotalSummary="True"
                   TotalSummaryPosition="Bottom"    />
            </dxg:GridControl.View>


        </dxg:GridControl>


    </Grid>
</dxwui:NavigationPage>
